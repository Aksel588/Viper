module math

export fn add(a: int, b: int) -> int {
    return a + b
}

export fn sub(a: int, b: int) -> int {
    return a - b
}

export fn mul(a: int, b: int) -> int {
    return a * b
}

export fn div(a: int, b: int) -> int {
    return a / b
}

export fn min(a: int, b: int) -> int {
    if a < b {
        return a
    }
    return b
}

export fn max(a: int, b: int) -> int {
    if a > b {
        return a
    }
    return b
}
